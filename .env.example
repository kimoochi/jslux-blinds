# =====================================================
# JS LUX BLINDS — Environment Variables Template
# =====================================================
# This file is SAFE to commit to version control.
# Copy to .env.local and fill in your actual values.

# Web3Forms key (get free at https://web3forms.com)
NEXT_PUBLIC_WEB3FORMS_KEY=YOUR_WEB3FORMS_ACCESS_KEY_HERE

# Site URL
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Contact Info
NEXT_PUBLIC_BUSINESS_ADDRESS=Cebu City, Philippines
NEXT_PUBLIC_BUSINESS_PHONE=+XX XXX XXX XXXX
NEXT_PUBLIC_BUSINESS_EMAIL=your@email.com
NEXT_PUBLIC_BUSINESS_HOURS_WEEKDAY=Monday – Saturday: 8:00 AM – 6:00 PM
NEXT_PUBLIC_BUSINESS_HOURS_WEEKEND=Sunday: By Appointment Only

# Social Media
NEXT_PUBLIC_FACEBOOK_URL=https://facebook.com/yourpage
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/yourprofile

# Google Maps Embed URL (from Google Maps Share → Embed)
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_URL=YOUR_GOOGLE_MAPS_EMBED_URL

# Optional: Resend API (if using API route instead of Web3Forms)
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# RESEND_FROM_EMAIL=noreply@yourdomain.com
# RESEND_TO_EMAIL=your@email.com
